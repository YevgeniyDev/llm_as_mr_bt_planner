# Copy this file to .env and fill in the key for whichever provider you use.

# --- Anthropic (default provider) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Optional overrides:
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MAX_TOKENS=16000
# ANTHROPIC_TIMEOUT_SECONDS=120

# --- OpenAI (use with --provider openai) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Optional OpenAI-compatible endpoint overrides:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_SECONDS=60
# OPENAI_TEMPERATURE=0          # raise (e.g. 0.7) for best-of-N (--samples) diversity
